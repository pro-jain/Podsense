{
  "title": "PodSense - Kubernetes Monitoring",
  "panels": [
    {
      "title": "CPU Usage per Pod",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total[1m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "title": "Memory Usage per Pod",
      "type": "graph",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{namespace='default'}",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "title": "Pod Restarts",
      "type": "stat",
      "targets": [
        {
          "expr": "kube_pod_container_status_restarts_total",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "title": "Network Receive Bytes",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total[1m])",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
